<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Signup</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Sora:wght@600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-1: #fff7ed;
            --bg-2: #e0f2fe;
            --bg-3: #dcfce7;
            --text: #0f172a;
            --muted: #475569;
            --line: #e2e8f0;
            --card: #ffffff;
            --accent: #ea580c;
            --accent-dark: #c2410c;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: "Space Grotesk", "Segoe UI", sans-serif;
            color: var(--text);
            background:
                radial-gradient(circle at 0% 0%, var(--bg-2), transparent 40%),
                radial-gradient(circle at 100% 0%, var(--bg-3), transparent 40%),
                linear-gradient(145deg, var(--bg-1) 0%, #fef2f2 50%, #f8fafc 100%);
            min-height: 100vh;
            display: grid;
            place-items: center;
            padding: 24px;
        }

        .card {
            width: 100%;
            max-width: 500px;
            background: rgba(255, 255, 255, 0.9);
            border: 1px solid var(--line);
            border-radius: 16px;
            box-shadow: 0 14px 34px rgba(15, 23, 42, 0.1);
            padding: 22px;
        }

        h1 {
            margin: 0 0 8px;
            font-family: "Sora", "Segoe UI", sans-serif;
            font-size: 1.6rem;
        }

        .subtitle {
            margin: 0 0 18px;
            color: var(--muted);
            font-size: 0.94rem;
        }

        .field {
            margin-bottom: 12px;
        }

        label {
            display: inline-block;
            margin-bottom: 6px;
            font-weight: 600;
            font-size: 0.9rem;
        }

        input {
            width: 100%;
            border: 1px solid #cbd5e1;
            border-radius: 8px;
            padding: 10px 12px;
            font-size: 0.95rem;
        }

        input:focus {
            border-color: var(--accent);
            outline: 2px solid rgba(234, 88, 12, 0.25);
            outline-offset: 1px;
        }

        .actions {
            margin-top: 8px;
            display: grid;
            gap: 8px;
        }

        .btn {
            border: none;
            border-radius: 9px;
            padding: 10px 14px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            text-align: center;
        }

        .btn-primary {
            color: #fff;
            background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 100%);
        }

        .btn-secondary {
            color: #0f172a;
            background: #fff;
            border: 1px solid #cbd5e1;
        }

        .helper {
            margin-top: 10px;
            color: var(--muted);
            font-size: 0.9rem;
            text-align: center;
        }

        .helper a {
            color: #9a3412;
            font-weight: 700;
            text-decoration: none;
        }
    </style>
</head>
<body>
    <div class="card">
        <h1>Signup</h1>
        <p class="subtitle">Create your account to manage products.</p>

        <form action="/signup" method="POST">
            <div class="field">
                <label for="username">Username</label>
                <input id="username" type="text" name="username" required>
            </div>

            <div class="field">
                <label for="email">Email</label>
                <input id="email" type="email" name="email" required>
            </div>

            <div class="field">
                <label for="password">Password</label>
                <input id="password" type="password" name="password" minlength="6" required>
            </div>

            <div class="actions">
                <button class="btn btn-primary" type="submit">Create Account</button>
                <a href="/products" class="btn btn-secondary">View Products</a>
            </div>
        </form>

        <p class="helper">Already have an account? <a href="/login">Login</a></p>
    </div>
</body>
</html>

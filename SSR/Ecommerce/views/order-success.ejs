<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Placed</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Sora:wght@600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-1: #f0fdf4;
            --bg-2: #dcfce7;
            --bg-3: #ecfeff;
            --text: #0f172a;
            --card: #ffffff;
            --line: #d1fae5;
        }

        body {
            margin: 0;
            font-family: "Space Grotesk", "Segoe UI", sans-serif;
            color: var(--text);
            background:
                radial-gradient(circle at 0% 0%, var(--bg-2), transparent 45%),
                radial-gradient(circle at 100% 0%, var(--bg-3), transparent 45%),
                linear-gradient(145deg, var(--bg-1), #f8fafc);
            min-height: 100vh;
            display: grid;
            place-items: center;
            padding: 20px;
        }

        .card {
            width: 100%;
            max-width: 520px;
            background: rgba(255, 255, 255, 0.92);
            border: 1px solid var(--line);
            border-radius: 16px;
            box-shadow: 0 12px 30px rgba(15, 23, 42, 0.1);
            padding: 22px;
        }

        h1 {
            margin: 0 0 10px;
            font-family: "Sora", "Segoe UI", sans-serif;
            font-size: 1.6rem;
            color: #166534;
        }

        .line {
            margin: 8px 0;
            color: #334155;
        }

        .total {
            margin-top: 12px;
            font-size: 1.1rem;
            font-weight: 700;
            color: #0f766e;
        }

        .actions {
            margin-top: 14px;
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .btn {
            text-decoration: none;
            border: 1px solid #cbd5e1;
            background: #fff;
            color: #0f172a;
            border-radius: 8px;
            padding: 8px 12px;
            font-size: 0.9rem;
            font-weight: 600;
        }
    </style>
</head>
<body>
    <div class="card">
        <h1>Order Placed Successfully</h1>
        <p class="line">Product: <strong><%= product.name %></strong></p>
        <p class="line">Quantity: <strong><%= quantity %></strong></p>
        <p class="line">Unit Price: <strong>$<%= product.price %></strong></p>
        <p class="total">Total Amount: $<%= totalAmount.toFixed(2) %></p>

        <div class="actions">
            <a href="/products" class="btn">Continue Shopping</a>
            <a href="/products/<%= product._id %>/purchase" class="btn">Buy Again</a>
        </div>
    </div>
</body>
</html>

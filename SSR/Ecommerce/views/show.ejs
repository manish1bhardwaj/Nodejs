<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= product.name %> | Product Details</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Sora:wght@600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
    <script>
        (function () {
            if (typeof window === "undefined") return;
            const perf = window.performance;
            if (!perf) return;
            if (typeof perf.clearMarks !== "function") {
                perf.clearMarks = function () {};
            }
            if (typeof perf.clearMeasures !== "function") {
                perf.clearMeasures = function () {};
            }
        })();
    </script>
    <style>
        :root {
            --bg-1: #fff7ed;
            --bg-2: #e0f2fe;
            --bg-3: #dcfce7;
            --text: #0f172a;
            --muted: #475569;
            --line: #e2e8f0;
            --accent: #ea580c;
            --accent-dark: #c2410c;
        }

        body {
            margin: 0;
            font-family: "Space Grotesk", "Segoe UI", sans-serif;
            color: var(--text);
            background:
                radial-gradient(circle at 0% 0%, var(--bg-2), transparent 40%),
                radial-gradient(circle at 100% 0%, var(--bg-3), transparent 40%),
                linear-gradient(145deg, var(--bg-1) 0%, #fef2f2 50%, #f8fafc 100%);
            min-height: 100vh;
            padding: 24px 16px;
        }

        .page-wrap {
            max-width: 980px;
            margin: 0 auto;
        }

        .top-actions {
            display: flex;
            justify-content: space-between;
            gap: 10px;
            margin-bottom: 14px;
        }

        .top-actions form {
            margin: 0;
        }

        .detail-card {
            background: rgba(255, 255, 255, 0.92);
            border: 1px solid var(--line);
            border-radius: 16px;
            box-shadow: 0 12px 30px rgba(15, 23, 42, 0.1);
            overflow: hidden;
            display: grid;
            grid-template-columns: 1fr 1fr;
        }

        .detail-media {
            padding: 14px;
            background: #f8fafc;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .detail-image {
            width: 100%;
            max-width: 100%;
            height: auto;
            max-height: 430px;
            object-fit: contain;
            border-radius: 10px;
        }

        .detail-content {
            padding: 20px;
            display: grid;
            gap: 10px;
            align-content: start;
        }

        .title {
            margin: 0;
            font-family: "Sora", "Segoe UI", sans-serif;
            font-size: clamp(1.3rem, 2.8vw, 2rem);
        }

        .price {
            margin: 0;
            color: #9a3412;
            font-weight: 700;
            font-size: 1.05rem;
        }

        .desc {
            margin: 0;
            color: var(--muted);
            line-height: 1.6;
            font-size: 0.98rem;
            white-space: pre-wrap;
        }

        .detail-actions {
            display: flex;
            gap: 10px;
            margin-top: 8px;
            align-items: center;
        }

        .detail-actions form {
            margin: 0;
            flex: 0 0 auto;
        }

        .detail-actions .btn {
            border-radius: 8px;
            padding: 6px 12px;
            font-size: 0.88rem;
            font-weight: 600;
            line-height: 1.2;
            min-width: 118px;
        }

        .btn-edit {
            background: linear-gradient(135deg, #facc15 0%, #f59e0b 100%);
            border: 1px solid #f59e0b;
            color: #1f2937;
        }

        .btn-edit:hover {
            background: linear-gradient(135deg, #fbbf24 0%, #d97706 100%);
            color: #111827;
        }

        .btn-delete {
            background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
            border: 1px solid #dc2626;
            color: #ffffff;
            min-width: 108px;
        }

        .btn-delete:hover {
            background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
            color: #ffffff;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 100%);
            border: none;
        }

        @media (max-width: 840px) {
            .detail-card {
                grid-template-columns: 1fr;
            }

            .detail-image {
                max-height: 320px;
            }

            .top-actions {
                flex-direction: column;
            }

            .top-actions .btn {
                width: 100%;
            }

            .detail-actions {
                flex-direction: column;
                align-items: stretch;
            }

            .detail-actions form {
                width: 100%;
            }

            .detail-actions .btn {
                width: 100%;
                min-width: 0;
            }

        }
    </style>
</head>
<body>
    <div class="page-wrap">
        <div class="top-actions">
            <a href="/products" class="btn btn-outline-secondary">Back to Products</a>
            <a href="/products/new" class="btn btn-primary">Add New Product</a>
        </div>

        <article class="detail-card">
            <div class="detail-media">
                <img src="<%= product.image %>" alt="<%= product.name %>" class="detail-image">
            </div>
            <div class="detail-content">
                <h1 class="title"><%= product.name %></h1>
                <p class="price">$<%= product.price %></p>
                <p class="desc"><%= product.desc %></p>
                <div class="detail-actions">
                    <a href="/products/<%= product._id %>/edit" class="btn btn-edit">Edit</a>
                    <form action="/products/<%= product._id %>/delete" method="POST">
                        <button type="submit" class="btn btn-delete" onclick="return confirm('Delete this product?')">Delete</button>
                    </form>
                </div>
            </div>
        </article>
    </div>
</body>
</html>

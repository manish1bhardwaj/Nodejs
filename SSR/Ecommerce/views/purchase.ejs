<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Purchase Details</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Sora:wght@600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-1: #fff7ed;
            --bg-2: #e0f2fe;
            --bg-3: #dcfce7;
            --card: #ffffff;
            --line: #e2e8f0;
            --text: #0f172a;
            --muted: #475569;
            --accent: #ea580c;
            --accent-dark: #c2410c;
        }

        * { box-sizing: border-box; }

        body {
            margin: 0;
            font-family: "Space Grotesk", "Segoe UI", sans-serif;
            color: var(--text);
            background:
                radial-gradient(circle at 0% 0%, var(--bg-2), transparent 40%),
                radial-gradient(circle at 100% 0%, var(--bg-3), transparent 40%),
                linear-gradient(145deg, var(--bg-1) 0%, #fef2f2 50%, #f8fafc 100%);
            min-height: 100vh;
            padding: 24px 14px;
        }

        .page {
            max-width: 900px;
            margin: 0 auto;
        }

        .top-actions {
            display: flex;
            gap: 10px;
            margin-bottom: 12px;
        }

        .btn-link {
            border: 1px solid #cbd5e1;
            background: #fff;
            color: #0f172a;
            text-decoration: none;
            border-radius: 8px;
            padding: 8px 12px;
            font-weight: 600;
            font-size: 0.9rem;
        }

        .shell {
            background: rgba(255, 255, 255, 0.9);
            border: 1px solid var(--line);
            border-radius: 16px;
            box-shadow: 0 12px 30px rgba(15, 23, 42, 0.1);
            overflow: hidden;
            display: grid;
            grid-template-columns: 1fr 1fr;
        }

        .media {
            background: #f8fafc;
            display: grid;
            place-items: center;
            padding: 16px;
        }

        .media img {
            max-width: 100%;
            max-height: 360px;
            width: auto;
            height: auto;
            border-radius: 10px;
            object-fit: contain;
        }

        .content {
            padding: 20px;
        }

        .tag {
            display: inline-flex;
            background: #fff7ed;
            border: 1px solid #fdba74;
            color: #9a3412;
            border-radius: 999px;
            padding: 5px 10px;
            font-size: 0.8rem;
            font-weight: 700;
        }

        h1 {
            margin: 10px 0 8px;
            font-family: "Sora", "Segoe UI", sans-serif;
            font-size: clamp(1.2rem, 2.2vw, 1.8rem);
        }

        .price {
            margin: 0 0 10px;
            color: #9a3412;
            font-size: 1rem;
            font-weight: 700;
        }

        .desc {
            color: var(--muted);
            font-size: 0.95rem;
            line-height: 1.5;
            margin-bottom: 14px;
        }

        .field {
            margin-bottom: 12px;
        }

        label {
            display: inline-block;
            font-weight: 600;
            margin-bottom: 6px;
            font-size: 0.9rem;
        }

        input {
            width: 100%;
            border: 1px solid #cbd5e1;
            border-radius: 8px;
            padding: 9px 10px;
            font-size: 0.94rem;
        }

        .note {
            margin: 0 0 12px;
            color: var(--muted);
            font-size: 0.87rem;
        }

        .btn-place {
            border: none;
            width: 100%;
            border-radius: 9px;
            padding: 10px 14px;
            color: #fff;
            font-weight: 700;
            background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 100%);
            cursor: pointer;
        }

        @media (max-width: 820px) {
            .shell { grid-template-columns: 1fr; }
            .top-actions { flex-direction: column; }
            .btn-link { text-align: center; }
        }
    </style>
</head>
<body>
    <div class="page">
        <div class="top-actions">
            <a href="/products" class="btn-link">Back to Products</a>
            <a href="/" class="btn-link">Back to Home</a>
        </div>

        <section class="shell">
            <div class="media">
                <img src="<%= product.image %>" alt="<%= product.name %>">
            </div>
            <div class="content">
                <span class="tag">Purchase Details</span>
                <h1><%= product.name %></h1>
                <p class="price">Unit Price: $<%= product.price %></p>
                <p class="desc"><%= product.desc %></p>

                <form action="/products/<%= product._id %>/purchase" method="POST">
                    <div class="field">
                        <label for="quantity">Quantity</label>
                        <input id="quantity" name="quantity" type="number" min="1" value="1" required>
                    </div>
                    <p class="note">Login is required to place the order.</p>
                    <button type="submit" class="btn-place">Place Order</button>
                </form>
            </div>
        </section>
    </div>
</body>
</html>

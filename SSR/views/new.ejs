<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add New Product</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
    <script>
        (function () {
            if (typeof window === "undefined") return;
            const perf = window.performance;
            if (!perf) return;
            if (typeof perf.clearMarks !== "function") {
                perf.clearMarks = function () {};
            }
            if (typeof perf.clearMeasures !== "function") {
                perf.clearMeasures = function () {};
            }
        })();
    </script>
    <style>
        :root {
            --bg-1: #fff7ed;
            --bg-2: #e0f2fe;
            --bg-3: #dcfce7;
            --card: #ffffff;
            --text: #1f2937;
            --muted: #6b7280;
            --accent: #ea580c;
            --accent-dark: #c2410c;
            --ring: rgba(234, 88, 12, 0.2);
        }

        body {
            font-family: "Space Grotesk", "Segoe UI", sans-serif;
            color: var(--text);
            background:
                radial-gradient(circle at 0% 0%, var(--bg-2), transparent 40%),
                radial-gradient(circle at 100% 0%, var(--bg-3), transparent 40%),
                linear-gradient(145deg, var(--bg-1) 0%, #fef2f2 50%, #f8fafc 100%);
            min-height: 100vh;
        }

        .page-wrap {
            max-width: 680px;
        }

        .form-card {
            background: var(--card);
            border: 1px solid #fed7aa;
            border-radius: 10px;
            box-shadow: 0 10px 24px rgba(251, 146, 60, 0.14);
            overflow: hidden;
        }

        .form-header {
            padding: 14px 16px;
            background: linear-gradient(120deg, #fff7ed 0%, #ffedd5 35%, #dcfce7 100%);
            border-bottom: 1px solid #fdba74;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 10px;
        }

        .form-header h1 {
            margin: 0;
            font-size: 1.2rem;
            font-weight: 700;
            letter-spacing: 0.2px;
        }

        .subtitle {
            margin: 2px 0 0;
            color: var(--muted);
            font-size: 0.85rem;
        }

        .form-body {
            padding: 16px;
        }

        .form-label {
            font-weight: 600;
            margin-bottom: 4px;
            font-size: 0.9rem;
        }

        .form-control {
            border-radius: 8px;
            border-color: #fdba74;
            padding: 8px 10px;
            background: #fffdf8;
            font-size: 0.95rem;
        }

        .form-control:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 4px var(--ring);
        }

        .actions {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 8px;
            margin-top: 4px;
        }

        .btn-create {
            background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
            border: none;
            color: #ffffff;
            padding: 10px 20px;
            font-weight: 600;
            border-radius: 8px;
        }

        .btn-create:hover {
            background: linear-gradient(135deg, #ea580c 0%, #c2410c 100%);
        }

        @media (max-width: 768px) {
            .form-header {
                flex-direction: column;
                align-items: flex-start;
            }

            .actions {
                justify-content: stretch;
                flex-direction: column-reverse;
                align-items: stretch;
            }

            .actions .btn {
                width: 100%;
            }
        }
    </style>
</head>
<body>
    <div class="container py-4 py-md-5 page-wrap">
        <div class="form-card">
            <div class="form-header">
                <div>
                    <h1>Add New Product</h1>
                    <p class="subtitle">Quick and easy product entry form</p>
                </div>
                <a href="/products" class="btn btn-outline-secondary">Back to Products</a>
            </div>

            <div class="form-body">
                <form action="/products" method="POST" class="row g-2">
                    <div class="col-12 col-md-8">
                        <label for="name" class="form-label">Product Name</label>
                        <input id="name" name="name" type="text" class="form-control" placeholder="Ex: Wireless Headphones" required>
                    </div>

                    <div class="col-12 col-md-4">
                        <label for="price" class="form-label">Price</label>
                        <input id="price" name="price" type="number" min="0" step="0.01" class="form-control" placeholder="Ex: 99.99" required>
                    </div>

                    <div class="col-12">
                        <label for="image" class="form-label">Image URL</label>
                        <input id="image" name="image" type="url" class="form-control" placeholder="https://example.com/image.jpg" required>
                    </div>

                    <div class="col-12">
                        <label for="desc" class="form-label">Description</label>
                        <textarea id="desc" name="desc" class="form-control" rows="4" placeholder="Write a short product description" required></textarea>
                    </div>

                    <div class="col-12 actions">
                        <a href="/products" class="btn btn-light border">Cancel</a>
                        <button type="submit" class="btn btn-create">Add Product</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</body>
</html>

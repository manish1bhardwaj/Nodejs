<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Products</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Sora:wght@600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
    <script>
        (function () {
            if (typeof window === "undefined") return;
            const perf = window.performance;
            if (!perf) return;
            if (typeof perf.clearMarks !== "function") {
                perf.clearMarks = function () {};
            }
            if (typeof perf.clearMeasures !== "function") {
                perf.clearMeasures = function () {};
            }
        })();
    </script>
    <style>
        :root {
            --bg-1: #fff7ed;
            --bg-2: #e0f2fe;
            --bg-3: #dcfce7;
            --text: #0f172a;
            --muted: #475569;
            --line: #e2e8f0;
            --card: #ffffff;
            --accent: #ea580c;
            --accent-dark: #c2410c;
        }

        body {
            margin: 0;
            font-family: "Space Grotesk", "Segoe UI", sans-serif;
            color: var(--text);
            background:
                radial-gradient(circle at 0% 0%, var(--bg-2), transparent 40%),
                radial-gradient(circle at 100% 0%, var(--bg-3), transparent 40%),
                linear-gradient(145deg, var(--bg-1) 0%, #fef2f2 50%, #f8fafc 100%);
            min-height: 100vh;
        }

        .page-wrap {
            max-width: 1150px;
            margin: 0 auto;
            padding: 24px 16px 32px;
        }

        .header-card {
            background: rgba(255, 255, 255, 0.88);
            border: 1px solid var(--line);
            border-radius: 14px;
            box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
            padding: 16px;
            margin-bottom: 16px;
        }

        .toolbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            margin-bottom: 10px;
        }

        .toolbar h1 {
            margin: 0;
            font-family: "Sora", "Segoe UI", sans-serif;
            font-size: clamp(1.35rem, 3vw, 2rem);
        }

        .summary {
            margin: 0;
            color: var(--muted);
            font-size: 0.98rem;
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            align-items: center;
        }

        .cart-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: #ecfeff;
            border: 1px solid #a5f3fc;
            border-radius: 999px;
            padding: 4px 10px;
            color: #155e75;
            font-size: 0.88rem;
            font-weight: 600;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 100%);
            border: none;
        }

        .grid {
            display: grid;
            gap: 12px;
            grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
        }

        .card {
            width: 100%;
            border: 1px solid var(--line);
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 6px 14px rgba(15, 23, 42, 0.08);
            transition: transform 0.16s ease, box-shadow 0.16s ease;
        }

        .card-link {
            text-decoration: none;
            color: inherit;
            display: block;
            flex: 1;
        }

        .card-shell {
            display: flex;
            flex-direction: column;
            height: 100%;
        }

        .card:hover {
            transform: translateY(-3px);
            box-shadow: 0 14px 28px rgba(15, 23, 42, 0.12);
        }

        .card-img-top {
            height: 150px;
            object-fit: cover;
        }

        .card-body {
            padding: 10px;
        }

        .card-title {
            font-size: 1rem;
            margin-bottom: 4px;
        }

        .price {
            color: #9a3412;
            font-weight: 700;
            margin-bottom: 6px;
            font-size: 0.95rem;
        }

        .card-text {
            font-size: 0.86rem;
            color: var(--muted);
            margin-bottom: 8px;
            line-height: 1.35;
            display: -webkit-box;
            line-clamp: 3;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .view-details {
            font-size: 0.84rem;
            color: var(--accent-dark);
            font-weight: 600;
        }

        .card-actions {
            padding: 0 10px 10px;
            margin-top: auto;
        }

        .action-row {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 6px;
            align-items: stretch;
        }

        .action-btn {
            width: 100%;
            display: inline-flex;
            justify-content: center;
            align-items: center;
            text-align: center;
            white-space: nowrap;
            font-size: 0.82rem;
            font-weight: 600;
            padding: 7px 9px;
            min-height: 38px;
        }

        .btn-cart {
            color: #fff;
            background: #0f766e;
            border-color: #0f766e;
        }

        .btn-cart:hover {
            color: #fff;
            background: #115e59;
            border-color: #115e59;
        }

        .btn-cart.in-cart {
            background: #0f766e;
            border-color: #0f766e;
            color: #ffffff;
            box-shadow: 0 4px 10px rgba(15, 118, 110, 0.26);
        }

        .btn-buy.added {
            background: #16a34a;
            border-color: #16a34a;
            color: #ffffff;
        }

        @media (max-width: 768px) {
            .toolbar {
                flex-direction: column;
                align-items: stretch;
            }

            .toolbar h1 {
                text-align: center;
            }

            .toolbar .btn {
                width: 100%;
            }

            .action-row {
                gap: 8px;
            }

            .action-btn {
                font-size: 0.84rem;
            }
        }

        @media (max-width: 920px) {
            .action-row {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 640px) {
            .action-btn {
                font-size: 0.84rem;
                padding: 8px 10px;
            }
        }

        @media (max-width: 420px) {
            .card-body {
                padding: 9px;
            }

            .card-actions {
                padding: 0 9px 9px;
            }

            .action-btn {
                min-height: 40px;
                font-size: 0.88rem;
            }
        }
    </style>
</head>
<body>
    <div class="page-wrap">
        <div class="header-card">
            <div class="toolbar">
                <a href="/" class="btn btn-outline-secondary">Back to Home</a>
                <h1>All Products</h1>
                <a href="/products/new" class="btn btn-primary">Add New Product</a>
            </div>
            <p class="summary">
                <span>Total Products: <strong><%= products.length %></strong></span>
                <span class="cart-pill">Cart Items: <strong id="cartCount">0</strong></span>
            </p>
        </div>

    <div class="grid">
        <% for (let product of products) { %>
            <div class="card">
                <div class="card-shell">
                    <a class="card-link" href="/products/<%= product._id %>">
                        <img src="<%= product.image %>" class="card-img-top" alt="<%= product.name %>">
                        <div class="card-body">
                            <h5 class="card-title"><%= product.name %></h5>
                            <h6 class="price">$<%= product.price %></h6>
                            <p class="card-text"><%= product.desc %></p>
                            <span class="view-details">View complete details</span>
                        </div>
                    </a>
                    <div class="card-actions">
                        <div class="action-row">
                            <a
                                href="/products/<%= product._id %>"
                                class="btn btn-success btn-sm action-btn btn-buy js-buy"
                                data-product-id="<%= product._id %>"
                                data-product-name="<%= product.name %>"
                                data-product-price="<%= product.price %>"
                                data-product-image="<%= product.image %>"
                            >Buy Now</a>
                            <button
                                type="button"
                                class="btn btn-cart btn-sm action-btn js-cart"
                                data-product-id="<%= product._id %>"
                                data-product-name="<%= product.name %>"
                                data-product-price="<%= product.price %>"
                                data-product-image="<%= product.image %>"
                            >Add to Cart</button>
                        </div>
                    </div>
                </div>
            </div>
        <% } %>
    </div>
    </div>

    <script>
        (function () {
            const CART_KEY = "ssr_cart_items";

            function readCart() {
                try {
                    const parsed = JSON.parse(localStorage.getItem(CART_KEY) || "[]");
                    return Array.isArray(parsed) ? parsed : [];
                } catch (_err) {
                    return [];
                }
            }

            function writeCart(items) {
                localStorage.setItem(CART_KEY, JSON.stringify(items));
            }

            function findItem(items, productId) {
                return items.find(function (item) {
                    return item.id === productId;
                });
            }

            function updateCartCount() {
                const countNode = document.getElementById("cartCount");
                if (!countNode) return;

                const items = readCart();
                const totalQuantity = items.reduce(function (sum, item) {
                    return sum + (Number(item.qty) || 0);
                }, 0);
                countNode.textContent = String(totalQuantity);
            }

            function refreshCartButtons() {
                const items = readCart();
                document.querySelectorAll(".js-cart").forEach(function (button) {
                    const productId = button.dataset.productId;
                    const inCart = Boolean(findItem(items, productId));
                    button.classList.toggle("in-cart", inCart);
                    button.textContent = inCart ? "Remove" : "Add to Cart";
                });
            }

            function getProductFromDataset(dataset) {
                return {
                    id: dataset.productId,
                    name: dataset.productName,
                    price: Number(dataset.productPrice),
                    image: dataset.productImage,
                    qty: 1
                };
            }

            document.querySelectorAll(".js-cart").forEach(function (button) {
                button.addEventListener("click", function () {
                    const product = getProductFromDataset(button.dataset);
                    const items = readCart();
                    const existing = findItem(items, product.id);

                    if (existing) {
                        const nextItems = items.filter(function (item) {
                            return item.id !== product.id;
                        });
                        writeCart(nextItems);
                    } else {
                        items.push(product);
                        writeCart(items);
                    }

                    refreshCartButtons();
                    updateCartCount();
                });
            });

            document.querySelectorAll(".js-buy").forEach(function (button) {
                button.addEventListener("click", function (event) {
                    event.preventDefault();
                    const product = getProductFromDataset(button.dataset);
                    const items = readCart();
                    const existing = findItem(items, product.id);

                    if (existing) {
                        existing.qty = (Number(existing.qty) || 0) + 1;
                    } else {
                        items.push(product);
                    }

                    writeCart(items);
                    refreshCartButtons();
                    updateCartCount();

                    const oldText = button.textContent;
                    button.textContent = "Added";
                    button.classList.add("added");

                    setTimeout(function () {
                        window.location.href = button.getAttribute("href");
                        button.textContent = oldText;
                        button.classList.remove("added");
                    }, 300);
                });
            });

            refreshCartButtons();
            updateCartCount();
        })();
    </script>
</body>
</html>
